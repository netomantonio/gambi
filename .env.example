# Credenciais e catálogo do GAMBI (copie para .env e preencha; .env é gitignored)
# realm = SLUG DA CONTA (copie do portal "Access Token"); NÃO é o literal "stackspot"
GAMBI_STACKSPOT_REALM=
GAMBI_STACKSPOT_CLIENT_ID=
GAMBI_STACKSPOT_CLIENT_SECRET=
# --- Catálogo de modelos: escolha UMA das duas formas (A ou B) ---
# (A) atalho simples por env (só modelo=agentId, sem flags por agent):
GAMBI_AGENTS=stackspot-dev=<agentId>,stackspot-arch=<agentId>
# (B) arquivo JSON — TEM PRIORIDADE sobre GAMBI_AGENTS. Suporta flags por agent
#     (structured_output, etc.) e alias por modo (modes: {ask, agent}).
#     Modelo em gambi.agents.example.json. Em produção, prefira caminho ABSOLUTO.
# GAMBI_AGENTS_FILE=./gambi.agents.json
# default de stackspot_knowledge p/ agents sem flag própria (true/false)
GAMBI_STACKSPOT_KNOWLEDGE=true
